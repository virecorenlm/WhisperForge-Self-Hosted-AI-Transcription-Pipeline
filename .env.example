# WhisperForge Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains your real credentials.

# Supabase project URL (found in: Supabase Dashboard > Project Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (found in: Supabase Dashboard > Project Settings > API)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
